EMPLOYER_ID=49971
EMPLOYER_URL=https://almaty.hh.kz/employer/49971



# ── Matching thresholds ───────────────────────────────────────────────────────
TFIDF_THRESHOLD=0.05
SEMANTIC_THRESHOLD=0.35
TOP_K=5

# ── Paths ─────────────────────────────────────────────────────────────────────
RESUMES_DIR=data/resumes
TFIDF_MODEL_PATH=data/tfidf_model.joblib
