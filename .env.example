IMAP_PORT=993
IMAP_USER=cv@company.com
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
EMAIL_POLL_INTERVAL=5

# ── LLM (Groq) ───────────────────────────────────────────────────────────────
